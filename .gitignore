# ============================
# IDE (PyCharm / IntelliJ)
# ============================
.idea/
*.iml

# ============================
# Python virtual environments
# ============================
.venv/
venv/
ENV/
env/

# ============================
# Python cache / build / test
# ============================
__pycache__/
*.py[cod]
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
build/
dist/
*.egg-info/

# ============================
# Logs
# ============================
*.log

# ============================
# OS junk
# ============================
.DS_Store
Thumbs.db
Desktop.ini

# ============================
# Secrets / env files
# ============================
.env
.env.*
!.env.example

# ============================
# Project-specific: data & outputs
# Keep only .gitkeep
# ============================
data/*
!data/.gitkeep

outputs/*
!outputs/.gitkeep

# Databases (if placed elsewhere)
*.db
*.sqlite
*.sqlite3

# ============================
# Jupyter (optional)
# ============================
.ipynb_checkpoints/

config/secrets.yml